{
	"name": "vscode-file-gen",
	"displayName": "vscode-file-gen",
	"description": "A VSCode extension for generating sets of files based on user specified templates",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.49.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:vscode-file-gen.helloWorld"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "vscode-file-gen.helloWorld",
				"title": "Hello World"
			}
		],
		"configuration": {
			"title": "VSCode File Gen",
			"properties": {
				"vscode-file-gen.file-template-groupings": {
					"type": "array",
					"description": "Groupings of file templates"
				},
				"vscode-file-gen.file-templates": {
					"type": "array",
					"description": "File template definitions"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"lint": "eslint '*/**/*.{js,ts}' --quiet --fix",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/glob": "^7.1.3",
		"@types/mocha": "^8.0.0",
		"@types/node": "^14.0.27",
		"@types/vscode": "^1.49.0",
		"@typescript-eslint/eslint-plugin": "^4.1.1",
		"@typescript-eslint/parser": "^4.1.1",
		"eslint": "^7.9.0",
		"eslint-config-prettier": "^6.12.0",
		"eslint-plugin-prettier": "^3.1.4",
		"glob": "^7.1.6",
		"mocha": "^8.1.3",
		"typescript": "^4.0.2",
		"vscode-test": "^1.4.0"
	}
}
